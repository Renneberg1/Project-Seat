    classDef outputConf fill:#F3E8FD,stroke:#9334E6,stroke-width:2px,color:#7627BB
    classDef dashStyle fill:#E6F4EA,stroke:#34A853,stroke-width:2px,color:#1E8E3E
    classDef monitorStyle fill:#E0F7FA,stroke:#00ACC1,stroke-width:2px,color:#00838F
