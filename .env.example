# Atlassian (Jira + Confluence)
ATLASSIAN_DOMAIN=yourcompany
ATLASSIAN_EMAIL=your.email@company.com
ATLASSIAN_API_TOKEN=your-api-token

# LLM Provider
LLM_PROVIDER=claude
LLM_API_KEY=your-llm-api-key
