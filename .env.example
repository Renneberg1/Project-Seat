# Atlassian (Jira + Confluence)
ATLASSIAN_DOMAIN=yourcompany
ATLASSIAN_EMAIL=your.email@company.com
ATLASSIAN_API_TOKEN=your-api-token

# LLM Provider
LLM_PROVIDER=claude
LLM_API_KEY=your-llm-api-key
LLM_MODEL=claude-sonnet-4-20250514

# eQMS / SoftComply DHF
EQMS_DRAFT_SPACE_ID=
EQMS_RELEASED_SPACE_ID=

# Zoom (General App — OAuth Authorization Code)
# Required scopes:
#   cloud_recording:read:list_user_recordings:admin  (cloud recordings)
#   meeting:read:list_meetings:admin                 (transcript-only scheduled meeting discovery)
# Note: Instant/ad-hoc meetings are not discoverable via API — use
# "Fetch by Meeting ID" on the Meetings page for those.
ZOOM_ENABLED=false
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_REDIRECT_URI=http://localhost:8000/zoom/callback
ZOOM_USER_ID=me

# Salesforce (future)
# SALESFORCE_INSTANCE_URL=
# SALESFORCE_ACCESS_TOKEN=
